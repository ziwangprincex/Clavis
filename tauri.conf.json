{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "web/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Clavis",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true,
        "save": true,
        "message": true,
        "ask": true,
        "confirm": true
      },
      "process": {
        "all": false,
        "relaunch": true
      },
      "window": {
        "all": false,
        "startDragging": true
      }
    },
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREQTNGQUMzRTUyRDYzNDAKUldSQVl5M2x3L3FqVGJxVGVqVHNpWkNlWU90dE1lM2FFQ1NHbjVvNjJudnRwTVhzUmlncTk3bk0K",
      "endpoints": [
        "https://github.com/ziwangprincex/Clavis/releases/latest/download/latest.json"
      ]
    },
    "bundle": {
      "active": true,
      "identifier": "com.clavis.app",
      "category": "Productivity",
      "shortDescription": "Markdown / LaTeX / Typst editor with live preview",
      "longDescription": "Native desktop editor with side-by-side preview for Markdown, LaTeX (real engine compilation via pdflatex/xelatex/lualatex), and Typst. Features include SyncTeX, BibTeX integration, project file sidebar, and PDF text search.",
      "targets": ["nsis", "dmg", "app", "deb", "appimage", "updater"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "wix": { "language": "en-US" }
      },
      "macOS": {
        "minimumSystemVersion": "11.0",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null,
        "entitlements": null
      }
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: https://ipc.localhost tauri://localhost"
    },
    "windows": [
      {
        "title": "Clavis — Markdown · LaTeX · Typst",
        "width": 1400,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
